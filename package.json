{
  "name": "@orchid-labs/pluxx",
  "version": "0.1.1",
  "description": "Build AI agent plugins once. Prime-time on Claude Code, Cursor, Codex, and OpenCode, with beta generators for additional hosts.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "pluxx": "bin/pluxx.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node && tsc --emitDeclarationOnly",
    "dev": "bun --watch src/cli/index.ts",
    "generate:compatibility": "bun scripts/generate-compatibility-matrix.ts",
    "pack:check": "npm pack --dry-run",
    "release:check": "bun run build && bun run typecheck && bun test && npm pack --dry-run",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build && bun run typecheck && bun test"
  },
  "files": [
    "bin/**/*",
    "src/**/*",
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai-agent",
    "plugin",
    "claude-code",
    "cursor",
    "opencode",
    "codex",
    "github-copilot",
    "agent-skills",
    "mcp",
    "sdk",
    "cross-platform"
  ],
  "author": {
    "name": "Brandon Guerrero",
    "url": "https://github.com/orchidautomation"
  },
  "license": "MIT",
  "homepage": "https://pluxx.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orchidautomation/pluxx.git"
  },
  "bugs": {
    "url": "https://github.com/orchidautomation/pluxx/issues"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "packageManager": "bun@1.2.17",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "zod": "^3.24.0"
  }
}
